# ML Drift Monitor — environment variables
# Copy to .env and fill in values

# ── Kaggle (dataset download) ──────────────────────────────
KAGGLE_USERNAME=your_kaggle_username
KAGGLE_KEY=your_kaggle_api_key

# ── API ────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# ── Dashboard ──────────────────────────────────────────────
DASHBOARD_PORT=8501
